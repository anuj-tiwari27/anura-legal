# ---------------------------------------------------------------------------
# Anura environment. Copy to `.env` (root) and fill in real values.
# The API reads this file; the web app reads NEXT_PUBLIC_* vars.
# Everything works locally with the docker-compose defaults below.
# Wire real providers by swapping the keys + provider selectors.
# ---------------------------------------------------------------------------

# --- Core ---
NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# --- Database (docker-compose Postgres + pgvector) ---
DATABASE_URL=postgresql://anura:anura@localhost:5442/anura?schema=public

# --- Redis (cache + BullMQ event queue; swap for SQS in prod) ---
REDIS_URL=redis://localhost:6380

# --- Auth (self-hosted JWT) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900          # 15 minutes (seconds)
JWT_REFRESH_TTL=1209600     # 14 days (seconds)
OTP_TTL=300                 # 5 minutes (seconds)

# --- Google sign-in (Google Identity Services) ---
# Create an OAuth 2.0 Web client in Google Cloud Console; add your web origins
# (http://localhost:3000 + production URL) as Authorized JavaScript origins.
# The SAME client ID goes in both vars (API verifies, web renders the button).
# Leave empty to hide the Google button and disable the endpoint (503).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- AI (drafting + chat). Provider: openai | anthropic ---
AI_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_CHAT_MODEL_OPENAI=gpt-4o
AI_CHAT_MODEL_ANTHROPIC=claude-opus-4-8
# Embeddings are always via OpenAI text-embedding-3-large (1536-dim slice used).
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# --- Object storage. Provider: minio | s3 | r2 | filesystem ---
STORAGE_PROVIDER=minio
STORAGE_BUCKET=anura-documents
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://localhost:9002
STORAGE_ACCESS_KEY_ID=anura
STORAGE_SECRET_ACCESS_KEY=anura-secret
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_URL=http://localhost:9002/anura-documents

# --- OCR. Provider: none | textract ---
OCR_PROVIDER=none
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- WhatsApp (Meta Cloud API). Provider: log | meta ---
WHATSAPP_PROVIDER=log
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=anura-verify
WHATSAPP_API_VERSION=v21.0

# --- Email (invoice sending). Provider: log | resend ---
EMAIL_PROVIDER=log
RESEND_API_KEY=
EMAIL_FROM=Anura <invoices@anura.legal>

# --- Billing. Provider: none | stripe | razorpay ---
PAYMENTS_PROVIDER=none
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GST_PERCENT=18

# --- Notifications (push). Provider: log | firebase ---
NOTIFICATIONS_PROVIDER=log
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- eCourts CNR lookup (ecourtsindia.com partner API). Provider: none | ecourtsindia ---
ECOURTS_PROVIDER=none
ECOURTS_API_URL=https://webapi.ecourtsindia.com
ECOURTS_API_TOKEN=

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
